# ─── Runtime ────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8080

# ─── Database (must match docker-compose.yml) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=votumdb
